<?xml version='1.0'?>
<!--
  Sample editor color scheme entries for the RPG II plugin tokens.
  Drop these into your plugin's color scheme XML (or the default
  `Rpg2ColorSettingsPage`) so users see sane defaults. These map the token
  names from rpg2.flex / rpg2.bnf to text attributes.
-->
<scheme>
    <attributes>
        <option name="RPG2_FORM_TYPE">
            <value>
                <option name="FOREGROUND" value="0000FF" />
                <option name="FONT_TYPE" value="1" />  <!-- bold -->
            </value>
        </option>
        <option name="RPG2_OPCODE">
            <value>
                <option name="FOREGROUND" value="000080" />
                <option name="FONT_TYPE" value="1" />
            </value>
        </option>
        <option name="RPG2_STRUCTURED">
            <value>
                <option name="FOREGROUND" value="000080" />
                <option name="FONT_TYPE" value="1" />
            </value>
        </option>
        <option name="RPG2_CMP_SUFFIX">
            <value>
                <option name="FOREGROUND" value="8080C0" />
            </value>
        </option>
        <option name="RPG2_KEYSET">
            <value>
                <option name="FOREGROUND" value="000080" />
                <option name="FONT_TYPE" value="1" />
            </value>
        </option>
        <option name="RPG2_CONTROL_LEVEL">
            <value>
                <option name="FOREGROUND" value="660E6A" />
            </value>
        </option>
        <option name="RPG2_INDICATOR">
            <value>
                <option name="FOREGROUND" value="FF8C00" />
                <option name="FONT_TYPE" value="1" />
            </value>
        </option>
        <option name="RPG2_DEVICE">
            <value>
                <option name="FOREGROUND" value="800080" />
            </value>
        </option>
        <option name="RPG2_STAR_VALUE">
            <value>
                <option name="FOREGROUND" value="0080FF" />
                <option name="FONT_TYPE" value="1" />
            </value>
        </option>
        <option name="RPG2_FILENAME">
            <value>
                <option name="FOREGROUND" value="008000" />
            </value>
        </option>
        <option name="RPG2_STRING">
            <value>
                <option name="FOREGROUND" value="008000" />
            </value>
        </option>
        <option name="RPG2_NUMBER">
            <value>
                <option name="FOREGROUND" value="0000FF" />
            </value>
        </option>
        <option name="RPG2_COPY">
            <value>
                <option name="FOREGROUND" value="808000" />
            </value>
        </option>
        <option name="RPG2_COMMENT">
            <value>
                <option name="FOREGROUND" value="808080" />
                <option name="FONT_TYPE" value="2" /> <!-- italic -->
            </value>
        </option>
        <option name="RPG2_BAD_CHAR">
            <value>
                <option name="FOREGROUND" value="FF0000" />
                <option name="EFFECT_COLOR" value="FF0000" />
                <option name="EFFECT_TYPE" value="2" /> <!-- wavily underlined -->
            </value>
        </option>
    </attributes>
</scheme>
