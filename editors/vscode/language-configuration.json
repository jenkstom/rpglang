{
  "comments": {
    "lineComment": "*"
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "(",  "close": ")"  },
    { "open": "'",  "close": "'",  "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*C\\s+BEGSR",
      "end":   "^\\s*C\\s+ENDSR"
    }
  },
  "wordPattern": "[A-Z@*/][A-Z0-9@*/\\-]*"
}
