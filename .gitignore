# =============================================================================
# RPG II Compiler - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Reference manuals (copyrighted / large - keep out of version control)
# -----------------------------------------------------------------------------
*.pdf
docs/ref/manual_layout.txt
docs/ref/manual_text.txt

# -----------------------------------------------------------------------------
# Build tree (CMake + compiler artifacts)
# -----------------------------------------------------------------------------
build/
[Bb]in/
[Oo]ut/
install/

# -----------------------------------------------------------------------------
# Compiler-emitted artifacts
# -----------------------------------------------------------------------------
# Object / assembly / IR / temporary files from rpgc & LLVM toolchain
*.o
*.obj
*.ll
*.s
*.bc
*.out

# Compiled RPG test executables
*.x

# --save-temps output
*.ll.tmp
*.save-temps/

# -----------------------------------------------------------------------------
# CMake
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeScripts/
CMakeUserPresets.json
compile_commands.json
CTestTestfile.cmake
Makefile
!compiler/CMakeLists.txt
!runtime/CMakeLists.txt
*.cmake
!*.cmake.in

# -----------------------------------------------------------------------------
# Static / shared libraries produced by the build
# -----------------------------------------------------------------------------
*.a
*.so
*.so.*
*.dylib
*.lib

# -----------------------------------------------------------------------------
# Core dumps & debug files
# -----------------------------------------------------------------------------
core
core.*
*.stackdump
compile_commands.json

# -----------------------------------------------------------------------------
# Debian/Ubuntu packaging byproducts
# -----------------------------------------------------------------------------
# dpkg-buildpackage / debhelper working state (debian/ *metadata* -- control,
# changelog, rules, copyright, source/format -- stays tracked).
debian/.debhelper/
debian/rpg2-compiler/
debian/tmp/
debian/*.debhelper
debian/*.debhelper.log
debian/*.substvars
debian/files
debian/debhelper-build-stamp
obj-*-linux-gnu*/
# dpkg-buildpackage drops these one directory above the source tree; ignore
# them wherever they land (e.g. if built from a sibling checkout layout).
*.deb
*.buildinfo
*.changes
*.dsc
*.tar.xz
build/pkg-deb/

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
.zcode/
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Tags & index files
# -----------------------------------------------------------------------------
tags
TAGS
GTAGS
GPATH
GSYMS
GRINFO
